# Model provider config example
# Copy this file to model-providers.env and fill real values locally.
# Do NOT commit model-providers.env.

MODEL_PROVIDER_ID=gpustack
MODEL_ID=gpustack/minimax-m2.1
MODEL_ALIAS="MiniMax M2.1"

# OpenClaw instances receive this proxy URL and an instance-scoped token.
# Real upstream URL/API key should be configured in openclaw-manager.env:
#   MODEL_PROXY_UPSTREAM_BASE_URL
#   MODEL_PROXY_UPSTREAM_API_KEY
MODEL_BASE_URL=http://openclaw-model-proxy:8081/v1
