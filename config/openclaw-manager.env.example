# OpenClaw Manager runtime configuration.
# Copy to config/openclaw-manager.env and adjust values for your host.

PUBLIC_HOST=127.0.0.1

OPENCLAW_PUBLIC_DIR=/data/docker/openclaw-public
OPENCLAW_MANAGER_DIR=/data/docker/openclaw-manager
OPENCLAW_VERSION=2026.5.26
TZ=Asia/Shanghai
OPENCLAW_INTERNAL_TOKEN=

# Exactly one provider is active. External provider names map to user_identities.provider.
MANAGER_AUTH_PROVIDER=nginx-basic
MANAGER_AUTH_TYPE=
MANAGER_SESSION_HOURS=8
MANAGER_COOKIE_SECURE=true
MANAGER_SESSION_SECRET=
MANAGER_ADMIN_USERS=openclaw
# External OAuth2/OIDC settings. Never commit real client secrets.
MANAGER_OAUTH_CLIENT_ID=
MANAGER_OAUTH_CLIENT_SECRET=
MANAGER_OAUTH_REDIRECT_URI=https://manager.example.test:30015/auth/callback
MANAGER_OIDC_DISCOVERY_URL=
MANAGER_OAUTH_AUTHORIZE_URL=
MANAGER_OAUTH_TOKEN_URL=
MANAGER_OAUTH_USERINFO_URL=
MANAGER_OAUTH_SCOPES=openid profile email
MANAGER_OAUTH_SUBJECT_CLAIM=sub
# Existing active platform administrators allowed through /emergency/login.
MANAGER_EMERGENCY_USERS=

PORT_START=30021
PORT_END=39999
PORT_FILE=/data/docker/openclaw-public/ports.txt
USERS_CSV=/data/docker/openclaw-public/users.csv

NGINX_COMPOSE_DIR=/data/docker/nginx/compose
NGINX_COMPOSE_FILE=/data/docker/nginx/compose/docker-compose.yml
NGINX_CONF_DIR=/data/docker/nginx/conf
NGINX_USERS_CONF_DIR=/data/docker/nginx/conf
NGINX_CERTS_DIR=/data/docker/nginx/certs
NGINX_LOGS_DIR=/data/docker/nginx/logs
NGINX_AUTH_DIR=/data/docker/nginx/auth
NGINX_AUTH_USERS_DIR=/data/docker/nginx/auth/users
NGINX_HTPASSWD_FILE=/data/docker/nginx/auth/.htpasswd
NGINX_HTPASSWD_FILE_IN_CONTAINER=/etc/nginx/auth/.htpasswd
NGINX_SSL_CERT=/etc/nginx/certs/openclaw.crt
NGINX_SSL_KEY=/etc/nginx/certs/openclaw.key
NGINX_CONTAINER_NAME=openclaw-nginx

DOCKER_NETWORK=agent-net
OPENCLAW_TENANT_NETWORK_PREFIX=openclaw-user
# Required: choose a dedicated IPv4 pool that does not overlap host, cloud,
# bastion, VPN, LAN, or other routed networks. Each tenant receives one /28.
OPENCLAW_TENANT_SUBNET_POOL=
OPENCLAW_TENANT_SUBNET_PREFIX=28
# Comma-separated CIDRs reachable through default routes and therefore not
# visible as specific host routes. Include bastion and VPN client networks.
OPENCLAW_TENANT_NETWORK_EXCLUDE_CIDRS=
# Allocation is serialized to prevent concurrent users receiving one subnet.
OPENCLAW_TENANT_NETWORK_LOCK_FILE=/data/docker/openclaw-public/tenant-network.lock

METADATA_DB_FILE=/data/docker/openclaw-public/manager.db

# Internal manager-control endpoint and per-service bearer tokens.
# Generate a different high-entropy token for each service. Never commit real values.
MANAGER_CONTROL_BASE_URL=http://manager-control:8082
MANAGER_CONTROL_USER_WEB_TOKEN=
MANAGER_CONTROL_ADMIN_WEB_TOKEN=
MANAGER_CONTROL_EXECUTOR_TOKEN=

MODEL_PROXY_PUBLIC_BASE_URL=http://openclaw-model-proxy:8081/v1
MODEL_PROXY_TOKEN_DIR=/data/docker/openclaw-public/model-proxy-tokens
MODEL_PROXY_UPSTREAM_BASE_URL=http://127.0.0.1:18080/v1
MODEL_PROXY_UPSTREAM_API_KEY=replace-with-your-upstream-api-key

# Comma-separated allowlist for admin-triggered bulk skill installation.
# Example: MANAGER_SKILL_PRESETS=agent-browser-clawdbot
MANAGER_SKILL_PRESETS=
MANAGER_SKILL_INSTALL_TIMEOUT=180

# Seconds to keep the WeChat bind command waiting for QR/link confirmation.
MANAGER_WECHAT_BIND_TIMEOUT=300
